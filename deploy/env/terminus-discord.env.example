# terminus-discord.env — the HOST credential contract for the Terminus-OS Discord tenant.
#
# Token-Fleet provisions the real file at /etc/terminus-os/discord.env (root:root, 0600) from
# its secret store. THIS example carries variable NAMES and placeholder shapes ONLY — never a
# real secret. Nothing in this file, and no token anywhere, belongs in the checkout.
#
# The loader (packages/discord/src/config.ts) is fail-loud and aggregate: a missing or empty
# value here makes the tenant refuse to start and name every gap in one pass.

# Discord guild (server) the tenant operates in.
TERMINUS_DISCORD_GUILD_ID=<discord guild id>

# Custodes identity — REUSES the existing Discord application/token, repointed at this tenant.
TERMINUS_DISCORD_CUSTODES_TOKEN=<custodes bot token>
TERMINUS_DISCORD_CUSTODES_APP_ID=<custodes application id>

# Imperial Guard identity — REUSES the existing app/token; its OpenClaw-era configuration is
# replaced by this env contract.
TERMINUS_DISCORD_GUARD_TOKEN=<guard bot token>
TERMINUS_DISCORD_GUARD_APP_ID=<guard application id>

# Voice transport credential — the deliberate replacement of the old daemon's INLINE OpenAI
# secret. Required whenever any identity is granted a voice capability (Custodes is, by the
# default policy in packages/discord/src/identity.ts).
TERMINUS_DISCORD_VOICE_OPENAI_API_KEY=<openai api key>

# Notification-router routes: one variable per logical text channel, TERMINUS_DISCORD_CHANNEL_
# <NAME>=<channel id>. The suffix (lowercased) is the logical route name agents address. Add as
# many as the fleet needs; zero is a legal (voice-only) bring-up.
TERMINUS_DISCORD_CHANNEL_ALERTS=<channel id>
TERMINUS_DISCORD_CHANNEL_FLEET=<channel id>
